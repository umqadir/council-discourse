---
import AlpineScript from "@components/AlpineScript.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import Badge from "@components/Badge.astro";
import ChapterCard from "@components/ChapterCard.astro";
import { getBodies, getMeeting } from "@lib/data";
import { meetingOgPath } from "@lib/og";
import { chapterTypeLabel, formatDate, formatDuration } from "@lib/format";

export function getStaticPaths() {
  return getBodies().flatMap((body) =>
    body.meetings.map((meeting) => ({
      params: { bodySlug: body.slug, meetingSlug: meeting.slug },
      props: { body, meeting },
    })),
  );
}

const { body, meeting } = Astro.props;
const chapterCounts = new Map<string, number>();

for (const chapter of meeting.chapters) {
  chapterCounts.set(chapter.type, (chapterCounts.get(chapter.type) ?? 0) + 1);
}

const chapterTypeEntries = [...chapterCounts.entries()].sort(([a], [b]) =>
  chapterTypeLabel(a).localeCompare(chapterTypeLabel(b)),
);
const selectedTypes = Object.fromEntries(chapterTypeEntries.map(([type]) => [type, true]));
const filterData = JSON.stringify(selectedTypes);
const summaryLead = meeting.summary.slice(0, 4);
const summaryTail = meeting.summary.slice(4);
const hasSummaryTail = summaryTail.length > 0;
const description = `${meeting.title} on ${formatDate(meeting.date)}. Read summaries and chaptered transcript timestamps.`;
const ogImage = meetingOgPath(body.slug, meeting.slug);

if (!getMeeting(body.slug, meeting.slug)) {
  throw new Error(`Missing meeting ${meeting.slug}`);
}
---

<BaseLayout title={`${meeting.title} - ${formatDate(meeting.date)}`} description={description} image={ogImage}>
  <AlpineScript />
  <Breadcrumbs
    items={[
      { label: "Home", href: "/" },
      { label: `${body.name} Meetings`, href: `/meetings/${body.slug}/` },
      { label: `${meeting.title} - ${formatDate(meeting.date)}` },
    ]}
  />

  <section class="mx-auto max-w-6xl px-4 py-8 md:px-6">
    <div class="max-w-reading space-y-3">
      <p class="text-sm font-semibold uppercase tracking-[0.16em] text-civic">{meeting.body}</p>
      <h1 class="font-serif text-4xl font-semibold leading-tight">{meeting.title}</h1>
      <div class="text-sm tabular text-muted">
        {formatDate(meeting.date)} · {meeting.time} · {formatDuration(meeting.duration_sec)}
      </div>
      <div class="flex flex-wrap gap-2 pt-1">
        {meeting.tags.map((tag) => <Badge type={tag} kind="meeting" />)}
      </div>
    </div>
  </section>

  <section
    class="mx-auto grid max-w-6xl gap-x-10 gap-y-8 px-4 pb-12 md:px-6 lg:grid-cols-[20rem_minmax(0,1fr)]"
    x-data={`{ selected: ${filterData} }`}
  >
    <aside class="min-w-0 lg:sticky lg:top-6 lg:self-start">
      <div class="border-t border-line pt-6">
        <h2 class="font-serif text-2xl font-semibold">Summary</h2>
        <div x-data="{ showAll: false }">
          <ul class="mt-4 space-y-3 leading-7 text-muted">
            {summaryLead.map((item) => <li class="border-l-2 border-line pl-4">{item}</li>)}
            {
              summaryTail.map((item) => (
                <li class="border-l-2 border-line pl-4" x-show="showAll" x-cloak>
                  {item}
                </li>
              ))
            }
          </ul>
          {
            hasSummaryTail && (
              <button
                type="button"
                class="mt-3 text-sm font-semibold text-civic underline decoration-line hover:text-civic-dark"
                @click="showAll = !showAll"
                x-text="showAll ? 'Less' : 'More'"
              >
                More
              </button>
            )
          }
        </div>
      </div>

      <div class="mt-8 border-t border-line pt-6">
        <h2 class="font-serif text-xl font-semibold">Chapter type</h2>
        <div class="mt-4 flex flex-wrap gap-x-5 gap-y-3 lg:flex-col lg:gap-0 lg:space-y-3">
          {
            chapterTypeEntries.map(([type, count]) => (
              <label class="flex items-center gap-3 text-sm lg:justify-between">
                <span class="flex items-center gap-2">
                  <input class="h-4 w-4 accent-civic" type="checkbox" x-model={`selected.${type}`} />
                  <span>{chapterTypeLabel(type)}</span>
                </span>
                <span class="tabular text-muted">{count}</span>
              </label>
            ))
          }
        </div>
      </div>
    </aside>

    <div class="min-w-0">
      <div class="mb-4 border-b border-line pb-3">
        <h2 class="font-serif text-3xl font-semibold">Meeting chapters</h2>
        <p class="mt-1 text-sm text-muted">Read summaries and jump into the video at the segment start.</p>
      </div>
      {meeting.chapters.map((chapter) => <ChapterCard meeting={meeting} chapter={chapter} />)}
    </div>
  </section>
</BaseLayout>
