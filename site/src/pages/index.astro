---
import BaseLayout from "@layouts/BaseLayout.astro";
import MeetingRow from "@components/MeetingRow.astro";
import { getMeetings } from "@lib/data";

const meetings = getMeetings();
const description =
  "Council Discourse publishes NYC Council meeting summaries, chapters, transcripts, and direct video timestamps.";
---

<BaseLayout title="Council Discourse" description={description}>
  <section class="mx-auto grid max-w-6xl gap-8 px-4 py-10 md:grid-cols-[minmax(0,1.4fr)_minmax(18rem,0.6fr)] md:px-6">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.16em] text-civic">Public meeting record</p>
      <h1 class="mt-3 font-serif text-5xl font-semibold leading-[1.02] md:text-6xl">
        NYC Council meetings, chaptered by time.
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-8 text-muted">
        Follow long public meetings through concise summaries, chapter lists, transcript timestamps,
        and the original council video.
      </p>
    </div>
    <aside class="self-end border-l-4 border-civic bg-wash/70 px-5 py-4">
      <h2 class="font-serif text-2xl font-semibold">Newsletter</h2>
      <p class="mt-2 leading-7 text-muted">
        A weekly email placeholder for newly processed meetings and notable chapters.
      </p>
      <div class="mt-4 flex gap-2">
        <input
          class="min-w-0 flex-1 border border-line bg-paper px-3 py-2 text-sm"
          type="email"
          placeholder="email@example.com"
          aria-label="Email address"
          disabled
        />
        <button class="bg-civic px-4 py-2 text-sm font-semibold text-white" type="button" disabled>
          Soon
        </button>
      </div>
    </aside>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-12 md:px-6">
    <div class="mb-4 flex items-end justify-between gap-4 border-b border-line pb-3">
      <div>
        <h2 class="font-serif text-3xl font-semibold">Recent meetings</h2>
        <p class="mt-1 text-sm text-muted">Benchmark meetings currently loaded from local pipeline artifacts.</p>
      </div>
      <a class="hidden text-sm font-semibold underline decoration-line hover:decoration-civic md:inline" href="/meetings/new-york-city-council/">
        All council meetings
      </a>
    </div>
    <div x-data="{ visible() { return true } }">
      {meetings.map((meeting) => <MeetingRow meeting={meeting} />)}
    </div>
  </section>
</BaseLayout>
