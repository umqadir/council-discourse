---
import BaseLayout from "@layouts/BaseLayout.astro";
import AlpineScript from "@components/AlpineScript.astro";
import MeetingRow from "@components/MeetingRow.astro";
import { getMeetings } from "@lib/data";
import { meetingTagLabel } from "@lib/format";
import { homeOgPath } from "@lib/og";
import type { MeetingTag } from "@lib/types";

const meetings = getMeetings();
const tagCounts = new Map<MeetingTag, number>();

for (const meeting of meetings) {
  for (const tag of meeting.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}

const tagEntries = [...tagCounts.entries()];
const selectedTags = Object.fromEntries(tagEntries.map(([tag]) => [tag, true]));
const filterData = JSON.stringify(selectedTags);
const description =
  "Council Discourse publishes NYC Council meeting summaries, chapters, transcripts, and direct video timestamps.";
---

<BaseLayout title="Council Discourse" description={description} image={homeOgPath}>
  <AlpineScript />
  <h1 class="sr-only">Council Discourse</h1>

  <section
    class="mx-auto grid max-w-6xl gap-8 px-4 py-8 md:grid-cols-[14rem_minmax(0,1fr)] md:px-6"
    x-data={`{ selected: ${filterData}, visible(tags) { return tags.split(' ').some((tag) => this.selected[tag]); } }`}
  >
    <aside class="md:pt-2">
      <details class="border-y border-line py-3 md:hidden">
        <summary class="cursor-pointer font-semibold">Filter by tag</summary>
        <div class="mt-4 space-y-3">
          {
            tagEntries.map(([tag, count]) => (
              <label class="flex items-center justify-between gap-3 text-sm">
                <span class="flex items-center gap-2">
                  <input class="h-4 w-4 accent-civic" type="checkbox" x-model={`selected.${tag}`} />
                  <span>{meetingTagLabel(tag)}</span>
                </span>
                <span class="tabular text-muted">{count}</span>
              </label>
            ))
          }
        </div>
      </details>
      <div class="hidden md:block">
        <h2 class="font-serif text-xl font-semibold">Filters</h2>
        <div class="mt-4 space-y-3">
          {
            tagEntries.map(([tag, count]) => (
              <label class="flex items-center justify-between gap-3 text-sm">
                <span class="flex items-center gap-2">
                  <input class="h-4 w-4 accent-civic" type="checkbox" x-model={`selected.${tag}`} />
                  <span>{meetingTagLabel(tag)}</span>
                </span>
                <span class="tabular text-muted">{count}</span>
              </label>
            ))
          }
        </div>
      </div>
    </aside>

    <div class="min-w-0">
      {meetings.map((meeting) => <MeetingRow meeting={meeting} />)}
    </div>
  </section>
</BaseLayout>
