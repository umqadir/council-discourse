---
import { chapterTypeLabel, meetingTagLabel } from "@lib/format";
import type { MeetingTag } from "@lib/types";

interface Props {
  type: string;
  kind?: "meeting" | "chapter";
}

const { type, kind = "chapter" } = Astro.props;
const labels =
  kind === "meeting" ? meetingTagLabel(type as MeetingTag) : chapterTypeLabel(type);

const chapterTone: Record<string, string> = {
  AGENCY_TESTIMONY: "bg-[#edf3ef] border-[#cbd8cf]",
  PROCEDURE: "bg-[#f0eee9] border-[#d8d1c6]",
  QA: "bg-[#edf1f4] border-[#ccd6de]",
  REMARKS: "bg-[#f4f0e6] border-[#ded5c2]",
  TESTIMONY: "bg-[#f2eee9] border-[#dacfc3]",
  VOTE: "bg-[#e9f0f6] border-[#c5d4e0]",
};

const meetingTone: Record<string, string> = {
  HEARING: "bg-paper border-line",
  LAND_USE: "bg-[#f2eee9] border-[#dacfc3]",
  STATED_MEETING: "bg-[#e9f0f6] border-[#c5d4e0]",
  VOTE: "bg-[#edf1f4] border-[#ccd6de]",
};

const tone = kind === "meeting" ? meetingTone[type] : chapterTone[type];
---

<span
  class:list={[
    "inline-flex items-center rounded-full border px-2.5 py-1 text-[0.68rem] font-semibold uppercase leading-none tracking-[0.08em] text-ink",
    tone ?? "bg-paper border-line",
  ]}
>
  {labels}
</span>
