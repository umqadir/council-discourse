---
import { chapterTypeLabel, formatClock } from "@lib/format";
import type { Meeting } from "@lib/types";

interface Props {
  meeting: Meeting;
}

const { meeting } = Astro.props;
const count = meeting.chapters.length;
---

{
  count > 6 && (
    <nav
      class="chapter-trail fixed left-2 top-1/2 z-20 hidden max-h-[72vh] -translate-y-1/2 flex-col items-start justify-center gap-1 py-2 xl:flex"
      data-preview="false"
      aria-label="Chapter minimap"
    >
      {/* One preview card, repositioned to whichever tick is hovered — the
          hover-card model from the shadcn MessageScroller outline. */}
      <div
        class="chapter-trail-card pointer-events-none absolute left-full top-0 ml-3 hidden w-72 max-w-[19rem] -translate-y-1/2 flex-col gap-1.5 rounded-lg border border-line bg-paper p-3 shadow-lg ring-1 ring-ink/5"
      >
        <div class="flex items-center gap-2">
          <span
            class="chapter-trail-card-badge inline-flex items-center rounded-full border border-line bg-paper px-2 py-0.5 text-[0.6rem] font-semibold uppercase leading-none tracking-[0.08em] text-ink"
            data-card-badge
          />
          <span class="tabular text-xs text-muted" data-card-clock />
        </div>
        <p class="font-serif text-sm font-semibold leading-snug text-ink" data-card-title />
        <p class="line-clamp-2 text-xs leading-relaxed text-muted" data-card-summary />
      </div>

      {meeting.chapters.map((chapter, index) => (
        <button
          type="button"
          class="chapter-tick group flex h-2 w-8 items-center justify-start border-0 bg-transparent p-0"
          data-index={index}
          data-type={chapter.type}
          data-badge={chapterTypeLabel(chapter.type)}
          data-clock={formatClock(chapter.start_sec)}
          data-title={chapter.title}
          data-summary={chapter.summary}
          aria-label={`Jump to: ${chapter.title}`}
          x-show="selected[$el.dataset.type]"
          x-cloak
        >
          {/* The bar itself, matching the shadcn tick: dim by default, filled
              when its chapter is the current one, widened on hover/focus.
              State is driven by data-attributes (below) rather than conflicting
              Tailwind width utilities, so the width actually changes. */}
          <span class="chapter-tick-bar" data-current="false" data-active="false" />
        </button>
      ))}
    </nav>
  )
}

<style>
  .chapter-tick-bar {
    height: 2px;
    width: 12px;
    border-radius: 9999px;
    background: rgba(98, 95, 88, 0.35);
    transition:
      width 0.12s ease,
      background-color 0.12s ease;
  }
  /* Scroll position is visible only while the rail is not being previewed. */
  .chapter-trail[data-preview="false"] .chapter-tick-bar[data-current="true"] {
    width: 20px;
    background: #141311;
  }
  /* Active: the hovered/focused tick — widest and filled. */
  .chapter-tick-bar[data-active="true"] {
    width: 26px;
    background: #141311;
  }
  /* Transfer ownership immediately so two locations never look selected. */
  .chapter-trail[data-preview="true"] .chapter-tick-bar {
    transition: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .chapter-tick-bar {
      transition: none;
    }
  }
</style>

<script>
  const trail = document.querySelector<HTMLElement>(".chapter-trail");
  if (trail) {
    const ticks = [...trail.querySelectorAll<HTMLButtonElement>(".chapter-tick")];
    const cards = [...document.querySelectorAll<HTMLElement>("[data-chapter-card]")];
    const card = trail.querySelector<HTMLElement>(".chapter-trail-card");
    const badge = card?.querySelector<HTMLElement>("[data-card-badge]");
    const clock = card?.querySelector<HTMLElement>("[data-card-clock]");
    const title = card?.querySelector<HTMLElement>("[data-card-title]");
    const summary = card?.querySelector<HTMLElement>("[data-card-summary]");
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const barOf = (tick: HTMLElement) => tick.querySelector<HTMLElement>(".chapter-tick-bar");

    // Current position: the last visible chapter to cross the reading line.
    // Exactly one tick owns this state, including after filters change.
    let currentIndex = -1;
    let raf = 0;
    const paintCurrent = () => {
      raf = 0;
      const readingLine = window.innerHeight / 3;
      const visible: number[] = [];
      for (let i = 0; i < cards.length; i += 1) {
        const bar = barOf(ticks[i]);
        if (!bar) continue;
        bar.dataset.current = "false";
        if (cards[i].offsetParent !== null) visible.push(i);
      }
      currentIndex = visible[0] ?? -1;
      for (const index of visible) {
        if (cards[index].getBoundingClientRect().top <= readingLine) currentIndex = index;
      }
      const currentBar = currentIndex >= 0 ? barOf(ticks[currentIndex]) : null;
      if (currentBar) currentBar.dataset.current = "true";
    };
    const requestPaintCurrent = () => {
      if (!raf) raf = requestAnimationFrame(paintCurrent);
    };
    window.addEventListener(
      "scroll",
      requestPaintCurrent,
      { passive: true },
    );
    window.addEventListener("resize", requestPaintCurrent, { passive: true });
    const filterObserver = new MutationObserver(requestPaintCurrent);
    for (const chapterCard of cards) {
      filterObserver.observe(chapterCard, { attributes: true, attributeFilter: ["style"] });
    }
    paintCurrent();

    // Hover/focus temporarily owns the only highlight. The current position
    // remains recorded, but its styling is neutral until preview ends.
    let active: HTMLElement | null = null;
    const setActive = (tick: HTMLElement | null) => {
      const prev = active && barOf(active);
      if (prev) prev.dataset.active = "false";
      active = tick;
      trail.dataset.preview = tick ? "true" : "false";
      const bar = tick && barOf(tick);
      if (bar) bar.dataset.active = "true";
    };

    const showCard = (tick: HTMLElement) => {
      setActive(tick);
      if (!card || !badge || !clock || !title || !summary) return;
      badge.textContent = tick.dataset.badge ?? "";
      clock.textContent = tick.dataset.clock ?? "";
      title.textContent = tick.dataset.title ?? "";
      summary.textContent = tick.dataset.summary ?? "";
      summary.style.display = tick.dataset.summary ? "" : "none";
      const trailBox = trail.getBoundingClientRect();
      const tickBox = tick.getBoundingClientRect();
      card.classList.remove("hidden");
      card.classList.add("flex");
      const cardHeight = card.getBoundingClientRect().height;
      const desiredCenter = tickBox.top + tickBox.height / 2;
      const minCenter = 8 + cardHeight / 2;
      const maxCenter = window.innerHeight - 8 - cardHeight / 2;
      const clampedCenter = Math.min(maxCenter, Math.max(minCenter, desiredCenter));
      card.style.top = `${clampedCenter - trailBox.top}px`;
    };
    const hideCard = () => {
      setActive(null);
      card?.classList.add("hidden");
      card?.classList.remove("flex");
    };

    let hovered: HTMLElement | null = null;
    let focused: HTMLElement | null = null;
    const syncPreview = () => {
      const tick = hovered ?? focused;
      if (tick) showCard(tick);
      else hideCard();
    };

    for (const tick of ticks) {
      const index = Number(tick.dataset.index);
      tick.addEventListener("mouseenter", () => {
        hovered = tick;
        syncPreview();
      });
      tick.addEventListener("focus", () => {
        if (!tick.matches(":focus-visible")) return;
        focused = tick;
        syncPreview();
      });
      tick.addEventListener("mouseleave", () => {
        if (hovered === tick) hovered = null;
        syncPreview();
      });
      tick.addEventListener("blur", () => {
        if (focused === tick) focused = null;
        syncPreview();
      });
      tick.addEventListener("click", () => {
        cards[index]?.scrollIntoView({ behavior: reducedMotion ? "auto" : "smooth", block: "start" });
      });
    }
  }
</script>
