---
import { formatClock } from "@lib/format";
import type { Meeting } from "@lib/types";

interface Props {
  meeting: Meeting;
}

const { meeting } = Astro.props;
const count = meeting.chapters.length;
---

{
  count > 1 && (
    <nav
      class="chapter-trail fixed right-3 top-1/2 z-20 hidden -translate-y-1/2 xl:block"
      aria-label="Chapter navigation trail"
    >
      <div
        class="chapter-trail-panel absolute right-full top-1/2 mr-2 hidden max-h-[60vh] w-64 -translate-y-1/2 overflow-y-auto rounded-[18px] bg-paper p-1 text-sm shadow-lg ring-1 ring-ink/10"
      >
        {meeting.chapters.map((chapter, index) => (
          <button
            type="button"
            class="chapter-trail-item flex h-8 w-full min-w-0 items-center gap-2 rounded-[14px] px-2 py-1.5 text-left hover:bg-ink/5"
            data-index={index}
            data-type={chapter.type}
            x-show="selected[$el.dataset.type]"
            x-cloak
          >
            <span class="tabular shrink-0 text-xs text-muted">{formatClock(chapter.start_sec)}</span>
            <span class="min-w-0 flex-1 truncate text-ink">{chapter.title}</span>
          </button>
        ))}
      </div>
      <div
        class="chapter-trail-trigger flex h-[min(60vh,540px)] w-9 flex-col items-center justify-center rounded-md"
        style={`gap: ${count > 90 ? "1px" : "4px"};`}
      >
        {meeting.chapters.map((chapter, index) => (
          <span
            class="chapter-pill h-0.5 w-4 min-h-px flex-none rounded-full bg-muted/40"
            style={count * (count > 90 ? 3 : 6) > 540 ? "flex: 1 1 0; max-height: 2px;" : ""}
            data-index={index}
            data-type={chapter.type}
            x-show="selected[$el.dataset.type]"
            x-cloak
          />
        ))}
      </div>
    </nav>
  )
}

<script>
  const trail = document.querySelector<HTMLElement>(".chapter-trail");
  if (trail) {
    const panel = trail.querySelector<HTMLElement>(".chapter-trail-panel");
    const items = [...trail.querySelectorAll<HTMLButtonElement>(".chapter-trail-item")];
    const pills = [...trail.querySelectorAll<HTMLElement>(".chapter-pill")];
    const cards = [...document.querySelectorAll<HTMLElement>("[data-chapter-card]")];
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    let currentIndex = 0;
    const setCurrent = (index: number) => {
      currentIndex = index;
      for (const pill of pills) {
        pill.classList.toggle("bg-ink", Number(pill.dataset.index) === index);
        pill.classList.toggle("bg-muted/40", Number(pill.dataset.index) !== index);
      }
      for (const item of items) {
        item.classList.toggle("bg-civic/10", Number(item.dataset.index) === index);
      }
    };

    // Scroll-spy: the current chapter is the last card whose top has passed
    // the reading line (a third down the viewport).
    let raf = 0;
    const updateCurrent = () => {
      raf = 0;
      const line = window.innerHeight / 3;
      let current = 0;
      for (let i = 0; i < cards.length; i += 1) {
        if (cards[i].offsetParent === null) continue; // filtered out
        if (cards[i].getBoundingClientRect().top <= line) current = i;
      }
      setCurrent(current);
    };
    window.addEventListener(
      "scroll",
      () => {
        if (!raf) raf = requestAnimationFrame(updateCurrent);
      },
      { passive: true },
    );
    updateCurrent();

    // Hover-card behavior: hovering the pill column opens the panel; it stays
    // open while the pointer is over either; closes shortly after leaving.
    let closeTimer = 0;
    const open = () => {
      window.clearTimeout(closeTimer);
      if (!panel || !panel.classList.contains("hidden")) return;
      panel.classList.remove("hidden");
      const target = items[currentIndex];
      if (target && target.offsetParent !== null) {
        panel.scrollTop = target.offsetTop - panel.clientHeight / 2 + target.clientHeight / 2;
      }
    };
    const scheduleClose = () => {
      window.clearTimeout(closeTimer);
      closeTimer = window.setTimeout(() => panel?.classList.add("hidden"), 150);
    };
    trail.addEventListener("mouseenter", open);
    trail.addEventListener("mouseleave", scheduleClose);
    trail.addEventListener("focusin", open);
    trail.addEventListener("focusout", scheduleClose);

    for (const item of items) {
      item.addEventListener("click", () => {
        const card = cards[Number(item.dataset.index)];
        card?.scrollIntoView({ behavior: reducedMotion ? "auto" : "smooth", block: "start" });
      });
    }
  }
</script>
