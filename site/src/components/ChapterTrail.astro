---
import { formatClock } from "@lib/format";
import type { Meeting } from "@lib/types";

interface Props {
  meeting: Meeting;
}

const { meeting } = Astro.props;
const count = meeting.chapters.length;
const dense = count > 90;
---

{
  count > 6 && (
    <nav
      class="chapter-trail fixed left-2 top-1/2 z-20 hidden -translate-y-1/2 xl:block"
      data-hovering="false"
      aria-label="Chapter outline"
    >
      <button
        type="button"
        class="chapter-trail-trigger flex h-[min(60vh,540px)] w-9 flex-col items-start justify-center rounded-md border-0 bg-transparent px-0 outline-none focus-visible:ring-2 focus-visible:ring-civic/40"
        style={`gap: ${dense ? "1px" : "4px"};`}
        aria-label="Open chapter outline"
        aria-expanded="false"
      >
        {meeting.chapters.map((chapter, index) => (
          <span
            class="chapter-pill h-0.5 w-4 min-h-px flex-none rounded-full bg-muted/40"
            style={count * (dense ? 3 : 6) > 540 ? "flex: 1 1 0; max-height: 2px;" : ""}
            data-index={index}
            data-type={chapter.type}
            data-current="false"
            x-show="selected[$el.dataset.type]"
            x-cloak
          />
        ))}
      </button>

      <div
        class="chapter-trail-panel absolute left-full top-1/2 ml-2 hidden max-h-[60vh] w-72 -translate-y-1/2 overflow-y-auto rounded-2xl bg-paper p-1 text-sm shadow-lg ring-1 ring-ink/10"
        data-hovering="false"
      >
        {meeting.chapters.map((chapter, index) => (
          <button
            type="button"
            class="chapter-trail-item flex min-h-7 w-full min-w-0 items-center gap-2 rounded-xl px-2 py-1.5 text-left outline-none"
            data-index={index}
            data-type={chapter.type}
            data-current="false"
            data-hovered="false"
            x-show="selected[$el.dataset.type]"
            x-cloak
          >
            <span class="tabular shrink-0 text-xs text-muted">{formatClock(chapter.start_sec)}</span>
            <span class="line-clamp-1 min-w-0 text-ink">{chapter.title}</span>
          </button>
        ))}
      </div>
    </nav>
  )
}

<style>
  .chapter-pill {
    transition: background-color 0.12s ease;
  }
  .chapter-pill[data-current="true"] {
    background: #141311;
  }
  .chapter-trail[data-hovering="true"] .chapter-pill[data-current="true"] {
    background: rgba(98, 95, 88, 0.4);
  }
  .chapter-trail-item {
    transition:
      background-color 0.12s ease,
      color 0.12s ease;
  }
  .chapter-trail-panel[data-hovering="false"] .chapter-trail-item[data-current="true"],
  .chapter-trail-item[data-hovered="true"],
  .chapter-trail-item:focus-visible {
    background: rgba(20, 19, 17, 0.07);
  }
  .chapter-trail[data-hovering="true"] .chapter-pill,
  .chapter-trail-panel[data-hovering="true"] .chapter-trail-item {
    transition: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .chapter-pill,
    .chapter-trail-item {
      transition: none;
    }
  }
</style>

<script>
  const trail = document.querySelector<HTMLElement>(".chapter-trail");
  if (trail) {
    const trigger = trail.querySelector<HTMLButtonElement>(".chapter-trail-trigger");
    const panel = trail.querySelector<HTMLElement>(".chapter-trail-panel");
    const pills = [...trail.querySelectorAll<HTMLElement>(".chapter-pill")];
    const items = [...trail.querySelectorAll<HTMLButtonElement>(".chapter-trail-item")];
    const cards = [...document.querySelectorAll<HTMLElement>("[data-chapter-card]")];
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    let currentIndex = -1;
    let raf = 0;
    const paintCurrent = () => {
      raf = 0;
      const readingLine = window.innerHeight / 3;
      const visible: number[] = [];

      for (let index = 0; index < cards.length; index += 1) {
        pills[index].dataset.current = "false";
        items[index].dataset.current = "false";
        items[index].removeAttribute("aria-current");
        if (cards[index].offsetParent !== null) visible.push(index);
      }

      currentIndex = visible[0] ?? -1;
      for (const index of visible) {
        if (cards[index].getBoundingClientRect().top <= readingLine) currentIndex = index;
      }

      if (currentIndex >= 0) {
        pills[currentIndex].dataset.current = "true";
        items[currentIndex].dataset.current = "true";
        items[currentIndex].setAttribute("aria-current", "location");
      }
    };
    const requestPaintCurrent = () => {
      if (!raf) raf = requestAnimationFrame(paintCurrent);
    };

    window.addEventListener("scroll", requestPaintCurrent, { passive: true });
    window.addEventListener("resize", requestPaintCurrent, { passive: true });
    const filterObserver = new MutationObserver(requestPaintCurrent);
    for (const chapterCard of cards) {
      filterObserver.observe(chapterCard, { attributes: true, attributeFilter: ["style"] });
    }
    paintCurrent();

    let closeTimer = 0;
    const open = () => {
      window.clearTimeout(closeTimer);
      if (!panel || !trigger) return;
      const wasHidden = panel.classList.contains("hidden");
      panel.classList.remove("hidden");
      trigger.setAttribute("aria-expanded", "true");
      if (wasHidden && currentIndex >= 0) {
        const current = items[currentIndex];
        panel.scrollTop = current.offsetTop - panel.clientHeight / 2 + current.clientHeight / 2;
      }
    };
    const close = () => {
      if (!panel || !trigger) return;
      panel.classList.add("hidden");
      trigger.setAttribute("aria-expanded", "false");
      trail.dataset.hovering = "false";
      panel.dataset.hovering = "false";
      for (const item of items) item.dataset.hovered = "false";
    };
    const scheduleClose = () => {
      window.clearTimeout(closeTimer);
      closeTimer = window.setTimeout(close, 150);
    };

    trail.addEventListener("mouseenter", open);
    trail.addEventListener("mouseleave", scheduleClose);
    trail.addEventListener("focusin", open);
    trail.addEventListener("focusout", scheduleClose);

    let hovered: HTMLElement | null = null;
    const setHovered = (item: HTMLElement | null) => {
      if (!panel) return;
      if (hovered) hovered.dataset.hovered = "false";
      hovered = item;
      if (hovered) hovered.dataset.hovered = "true";
      trail.dataset.hovering = hovered ? "true" : "false";
      panel.dataset.hovering = hovered ? "true" : "false";
    };

    for (const item of items) {
      const index = Number(item.dataset.index);
      item.addEventListener("mouseenter", () => setHovered(item));
      item.addEventListener("mouseleave", () => {
        if (hovered === item) setHovered(null);
      });
      item.addEventListener("focus", () => {
        if (item.matches(":focus-visible")) setHovered(item);
      });
      item.addEventListener("blur", () => {
        if (hovered === item) setHovered(null);
      });
      item.addEventListener("click", () => {
        cards[index]?.scrollIntoView({ behavior: reducedMotion ? "auto" : "smooth", block: "start" });
      });
    }
  }
</script>
