---
import "video.js/dist/video-js.css";

interface Props {
  url: string;
  poster: string;
  startSec: number;
  title: string;
}

const { url, poster, startSec, title } = Astro.props;
---

<div class="chapter-video border border-line bg-black">
  <video
    id="chapter-video"
    class="video-js vjs-default-skin vjs-big-play-centered vjs-16-9"
    controls
    preload="metadata"
    playsinline
    poster={poster}
    data-chapter-video
    data-start={startSec}
    aria-label={title}
  >
    <source src={url} type="video/mp4" />
  </video>
</div>

<script>
  import videojs from "video.js";

  function setupChapterVideo() {
    const element = document.querySelector("[data-chapter-video]");
    if (!element || element.dataset.videoReady === "true") {
      return;
    }
    element.dataset.videoReady = "true";

    const start = Number(element.dataset.start || 0);
    const player = videojs(element, {
      controls: true,
      fluid: true,
      preload: "metadata",
    });

    player.ready(() => {
      player.currentTime(start);
      player.pause();
      window.chapterVideoPlayer = player;
    });

    window.seekChapterVideo = (seconds) => {
      const wasPaused = player.paused();
      player.currentTime(Number(seconds));
      if (wasPaused) {
        player.pause();
      }
    };
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupChapterVideo, { once: true });
  } else {
    setupChapterVideo();
  }
</script>
