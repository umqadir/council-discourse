---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  frontmatter: {
    title: string;
    description: string;
  };
}

const { frontmatter } = Astro.props;
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <section class="mx-auto max-w-reading px-4 py-10 md:px-6">
    <h1 class="font-serif text-4xl font-semibold leading-tight">{frontmatter.title}</h1>
    <article class="prose-site mt-8 space-y-5 leading-8 text-ink">
      <slot />
    </article>
  </section>
</BaseLayout>
