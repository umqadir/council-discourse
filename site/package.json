{
  "name": "council-discourse-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "predev": "pnpm prepare:data",
    "prepare:data": "[ \"$SKIP_EXPORT\" = \"1\" ] || PYTHONPATH=.. UV_CACHE_DIR=../.uv-cache uv run --project .. python -m pipeline export-site --db ../data/registry.db",
    "videos:link": "node scripts/link-local-videos.mjs",
    "prebuild": "pnpm prepare:data",
    "build": "astro build",
    "preview": "astro preview --host 0.0.0.0"
  },
  "dependencies": {
    "@astrojs/cloudflare": "12.6.13",
    "@astrojs/sitemap": "^3.6.0",
    "@fontsource/inter": "^5.2.6",
    "@fontsource/source-serif-4": "^5.2.8",
    "alpinejs": "^3.15.2",
    "astro": "^5.16.4"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@resvg/resvg-wasm": "2.6.2",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "satori": "^0.26.0",
    "tailwindcss": "^3.4.17",
    "wrangler": "4.107.0"
  }
}
